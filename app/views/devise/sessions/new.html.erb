<div class="auth-shell">
  <div class="auth-grid row g-0 align-items-stretch">
    <div class="col-lg-5 p-0">
      <div class="auth-aside h-100 p-4 p-lg-5 d-flex flex-column justify-content-between">
        <div>
          <div class="section-label mb-3"><i class="bi bi-box-arrow-in-right"></i>Welcome back</div>
          <h1 class="display-6 fw-bold mb-3">Log in to continue buying and selling on campus.</h1>
          <p class="text-white-50 mb-4">Browse listings, chat with sellers, and manage your items in one place.</p>
          <div class="d-flex flex-wrap gap-2">
            <span class="soft-pill px-3 py-2">Fast sign-in</span>
            <span class="soft-pill px-3 py-2">Private chat</span>
            <span class="soft-pill px-3 py-2">Campus search</span>
          </div>
        </div>
        <div class="mt-4 hero-side-note p-3">
          <div class="small text-white-50 mb-1">New here?</div>
          <div class="fw-semibold">Create an account to post items and chat instantly.</div>
        </div>
      </div>
    </div>

    <div class="col-lg-7 p-3 p-lg-4">
      <div class="auth-card p-4 p-lg-5 h-100">
        <div class="mb-4">
          <div class="section-label mb-2"><i class="bi bi-shield-lock"></i>Secure access</div>
          <h2 class="h1 mb-2">Log in</h2>
          <p class="text-site-muted mb-0">Use your email and password to access CUHK Mart.</p>
        </div>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="mb-3">
            <%= f.label :email, class: "form-label fw-semibold" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label fw-semibold" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "form-control form-control-lg" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="form-check mb-4">
              <%= f.check_box :remember_me, class: "form-check-input" %>
              <%= f.label :remember_me, class: "form-check-label" %>
            </div>
          <% end %>

          <div class="d-grid gap-2">
            <%= f.submit "Log in", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>

        <div class="mt-4">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
