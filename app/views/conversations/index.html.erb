<% content_for :title, "Messages - CUHK Mart" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 mb-0"><i class="bi bi-chat-dots me-2 text-primary"></i>Messages</h2>
  </div>

  <% if @conversations.empty? %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <i class="bi bi-chat-square-text display-5 text-muted"></i>
        <p class="mt-3 mb-1 text-muted">No conversations yet.</p>
        <p class="small text-muted mb-0">Open any item and click Contact Seller to start.</p>
      </div>
    </div>
  <% else %>
    <div class="list-group shadow-sm">
      <% @conversations.each do |conversation| %>
        <% other = conversation.counterpart_for(current_user) %>
        <% last_message = conversation.messages.last %>
        <%= link_to conversation_path(conversation), class: "list-group-item list-group-item-action py-3" do %>
          <div class="d-flex w-100 justify-content-between">
            <h6 class="mb-1"><%= other.user_name %></h6>
            <small class="text-muted"><%= last_message ? time_ago_in_words(last_message.created_at) + " ago" : "New" %></small>
          </div>
          <p class="mb-1 text-muted small">Item: <%= conversation.item.title %></p>
          <small class="text-muted"><%= last_message ? truncate(last_message.body, length: 70) : "No messages yet" %></small>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
