<% content_for :title, "Browse Items – CUHK Mart" %>

<!-- Search & Filter Bar -->
<div class="bg-primary text-white py-4">
  <div class="container">
    <h1 class="h4 mb-3"><i class="bi bi-grid me-2"></i>Browse Items</h1>
    <%= form_with url: items_path, method: :get, class: "row g-2" do |f| %>
      <div class="col-12 col-md-5">
        <%= f.text_field :search, value: params[:search],
            placeholder: "Search items...", class: "form-control" %>
      </div>
      <div class="col-6 col-md-2">
        <%= f.select :category,
            options_for_select([['All Categories', '']] + Item::CATEGORIES.map { |c| [c, c] }, params[:category]),
            {}, class: "form-select" %>
      </div>
      <div class="col-6 col-md-3">
        <%= f.select :college,
            options_for_select([['All Colleges', '']] + Item::COLLEGES.reject { |c| c == 'Any College' }.map { |c| [c, c] }, params[:college]),
            {}, class: "form-select" %>
      </div>
      <div class="col-12 col-md-2 d-grid">
        <%= f.submit "Search", class: "btn btn-light" %>
      </div>
    <% end %>
  </div>
</div>

<div class="container py-4">
  <% if @items.empty? %>
    <div class="text-center py-5">
      <i class="bi bi-inbox display-1 text-muted"></i>
      <h4 class="mt-3 text-muted">No items found</h4>
      <p class="text-muted">Try adjusting your search or be the first to post!</p>
      <%= link_to "Post an Item", new_item_path, class: "btn btn-primary mt-1" %>
    </div>
  <% else %>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <p class="text-muted mb-0"><strong><%= @items.count %></strong> item(s) available</p>
      <%= link_to new_item_path, class: "btn btn-primary btn-sm" do %>
        <i class="bi bi-plus me-1"></i>Post an Item
      <% end %>
    </div>

    <div class="row g-3">
      <% @items.each do |item| %>
        <div class="col-sm-6 col-md-4 col-lg-3">
          <%= link_to item_path(item), class: "text-decoration-none text-dark" do %>
            <div class="card h-100 shadow-sm border-0 item-card">
              <div class="card-body pb-2">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div class="d-flex gap-1">
                    <span class="badge bg-secondary small"><%= item.category %></span>
                    <% if item.visibility_scope == "college_only" %>
                      <span class="badge bg-info text-dark small">College only</span>
                    <% else %>
                      <span class="badge bg-light text-dark border small">Campus</span>
                    <% end %>
                  </div>
                  <span class="fw-bold text-success">HK$<%= number_with_delimiter(item.price.to_i) %></span>
                </div>
                <h6 class="card-title mb-1"><%= truncate(item.title, length: 55) %></h6>
                <p class="card-text text-muted small"><%= truncate(item.description, length: 80) %></p>
              </div>
              <div class="card-footer bg-transparent border-top-0 pt-0 pb-2">
                <small class="text-muted">
                  <i class="bi bi-person me-1"></i><%= item.user.user_name %>
                  <% if item.location.present? %>
                    &middot; <i class="bi bi-geo-alt me-1"></i><%= item.location %>
                  <% end %>
                </small><br>
                <small class="text-muted"><i class="bi bi-clock me-1"></i><%= time_ago_in_words(item.created_at) %> ago</small>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
