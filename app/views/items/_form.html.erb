<% if @item.errors.any? %>
  <div class="alert alert-danger">
    <h6 class="fw-semibold mb-2">
      <%= pluralize(@item.errors.count, "error") %> prevented this listing from being saved:
    </h6>
    <ul class="mb-0 ps-3">
      <% @item.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<% content_for :head do %>
  <script>
    function initItemMeetupAutocomplete() {
      var input = document.getElementById("item_meetup_location");
      var latitudeInput = document.getElementById("item_latitude");
      var longitudeInput = document.getElementById("item_longitude");
      var form = input ? input.form : null;

      if (!input || input.dataset.autocompleteReady === "true" || !window.google || !google.maps || !google.maps.places) {
        return;
      }

      function clearSelectedLocation() {
        input.dataset.locationSelected = "false";

        if (latitudeInput) {
          latitudeInput.value = "";
        }

        if (longitudeInput) {
          longitudeInput.value = "";
        }
      }

      var autocomplete = new google.maps.places.Autocomplete(input, {
        types: ["geocode"],
        componentRestrictions: { country: "hk" }
      });

      input.dataset.autocompleteReady = "true";
      input.dataset.locationSelected = latitudeInput && latitudeInput.value && longitudeInput && longitudeInput.value ? "true" : "false";

      input.addEventListener("input", function() {
        clearSelectedLocation();
      });

      autocomplete.addListener("place_changed", function() {
        var place = autocomplete.getPlace();
        if (place && place.geometry && place.geometry.location) {
          if (place.formatted_address) {
            input.value = place.formatted_address;
          }

          if (latitudeInput) {
            latitudeInput.value = place.geometry.location.lat();
          }

          if (longitudeInput) {
            longitudeInput.value = place.geometry.location.lng();
          }

          input.dataset.locationSelected = "true";
        } else {
          clearSelectedLocation();
        }
      });

      if (form && form.dataset.meetupValidationReady !== "true") {
        form.dataset.meetupValidationReady = "true";

        form.addEventListener("submit", function(event) {
          if (!input.value.trim()) {
            event.preventDefault();
            alert("Please enter a preferred meetup location.");
            input.focus();
            return;
          }

          if (input.dataset.locationSelected !== "true" || !latitudeInput.value || !longitudeInput.value) {
            event.preventDefault();
            alert("Please select a preferred meetup location from the Google Maps suggestions.");
            input.focus();
          }
        });
      }
    }

    if (!window.itemMeetupAutocompleteTurboHandlerAttached) {
      document.addEventListener("turbo:load", initItemMeetupAutocomplete);
      window.itemMeetupAutocompleteTurboHandlerAttached = true;
    }
  </script>
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= ENV['GOOGLE_MAPS_API_KEY'] %>&libraries=places&callback=initItemMeetupAutocomplete" async defer></script>
<% end %>

<%= form_with model: @item do |f| %>
  <%= f.hidden_field :latitude, id: "item_latitude" %>
  <%= f.hidden_field :longitude, id: "item_longitude" %>

  <div class="mb-3">
    <%= f.label :title, class: "form-label fw-semibold" %>
    <%= f.text_field :title, class: "form-control #{'is-invalid' if @item.errors[:title].any?}",
        placeholder: "e.g. Barely used MacBook Pro 2023", maxlength: 100 %>
    <div class="form-text text-muted">Max 100 characters</div>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label fw-semibold" %>
    <%= f.text_area :description, class: "form-control #{'is-invalid' if @item.errors[:description].any?}",
        rows: 5, placeholder: "Describe condition, age, included accessories, reason for selling..." %>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-4">
      <%= f.label :price, "Price (HKD)", class: "form-label fw-semibold" %>
      <div class="input-group">
        <span class="input-group-text">HK$</span>
        <%= f.number_field :price, class: "form-control #{'is-invalid' if @item.errors[:price].any?}",
            min: 0, step: 1, placeholder: "0" %>
      </div>
    </div>

    <div class="col-md-4">
      <%= f.label :category, class: "form-label fw-semibold" %>
      <%= f.select :category,
          options_for_select([['Select a category', '']] + Item::CATEGORIES.map { |c| [c, c] }, @item.category),
          {}, class: "form-select #{'is-invalid' if @item.errors[:category].any?}" %>
    </div>

    <div class="col-md-4">
      <%= f.label :location, "Preferred Meetup Location", class: "form-label fw-semibold" %>
      <%= f.text_field :location,
          id: "item_meetup_location",
          class: "form-control #{'is-invalid' if @item.errors[:location].any?}",
          autocomplete: "off",
          required: true,
          placeholder: "Search a meetup location and select it" %>
      <% @item.errors[:location].each do |message| %>
        <div class="invalid-feedback d-block"><%= message %></div>
      <% end %>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <%= f.label :visibility_scope, "Visibility", class: "form-label fw-semibold" %>
      <%= f.select :visibility_scope,
          options_for_select([["Campus-wide", "campus"], ["My college only", "college_only"]], @item.visibility_scope.presence || "campus"),
          {}, class: "form-select" %>
    </div>
    <div class="col-md-6">
      <%= f.label :visibility_college, "Visible College (if restricted)", class: "form-label fw-semibold" %>
      <%= f.select :visibility_college,
          options_for_select([["Use my college", current_user.college]] + User::COLLEGES.map { |c| [c, c] }, @item.visibility_college.presence || current_user.college),
          {}, class: "form-select" %>
      <div class="form-text text-muted">Choose campus-wide or limit visibility to one college.</div>
    </div>
  </div>

  <div class="d-flex gap-2 pt-2">
    <%= f.submit @item.new_record? ? "Post Listing" : "Update Listing",
        class: "btn btn-primary px-4" %>
    <%= link_to "Cancel",
        @item.new_record? ? items_path : item_path(@item),
        class: "btn btn-outline-secondary" %>
  </div>
<% end %>
