<% content_for :title, "My Listings – CUHK Mart" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"><i class="bi bi-person-lines-fill me-2 text-primary"></i>My Listings</h2>
    <%= link_to new_item_path, class: "btn btn-primary btn-sm" do %>
      <i class="bi bi-plus me-1"></i>Post New Item
    <% end %>
  </div>

  <% if @items.empty? %>
    <div class="text-center py-5">
      <i class="bi bi-inbox display-1 text-muted"></i>
      <h4 class="mt-3 text-muted">No listings yet</h4>
      <p class="text-muted">Start selling unused items to fellow CUHK students.</p>
      <%= link_to "Post Your First Item", new_item_path, class: "btn btn-primary mt-1" %>
    </div>
  <% else %>
    <div class="card shadow-sm border-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Title</th>
              <th>Category</th>
              <th>Price</th>
              <th>Status</th>
              <th>Listed</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @items.each do |item| %>
              <tr>
                <td>
                  <%= link_to truncate(item.title, length: 50), item_path(item),
                        class: "text-decoration-none fw-semibold" %>
                </td>
                <td><span class="badge bg-secondary"><%= item.category %></span></td>
                <td class="text-success fw-semibold">HK$<%= number_with_delimiter(item.price.to_i) %></td>
                <td>
                  <span class="badge bg-<%= item.status_color %>">
                    <%= item.status.capitalize %>
                  </span>
                </td>
                <td><small class="text-muted"><%= item.created_at.strftime("%b %d, %Y") %></small></td>
                <td class="text-end">
                  <%= link_to edit_item_path(item), class: "btn btn-outline-primary btn-sm me-1" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to item_path(item), method: :delete,
                        data: { turbo_confirm: "Delete '#{item.title}'?" },
                        class: "btn btn-outline-danger btn-sm" do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
